# Copy this file to .env for local dev, or set these as Variables in Railway.
# NEVER commit your real .env file or paste your real key anywhere public
# (including in chat with an AI assistant) — treat it like a password.

# Get this from https://openrouter.ai/keys — keep it secret, server-side only.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model slug. Use the ":free" variant while testing to spend zero credits:
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# How long to wait for the model provider before giving up, and how many
# times to retry a failed/slow call before returning an error to the user.
OPENROUTER_TIMEOUT_MS=25000
OPENROUTER_MAX_RETRIES=1

# Your deployed URL, sent to OpenRouter as an attribution header. Optional.
PUBLIC_APP_URL=https://hoodwise.xyz

# Local dev port (Railway sets PORT automatically in production).
PORT=3000
NODE_ENV=development

# Where the SQLite file lives. On Railway, once you attach a Volume, set this
# to something like /data/hoodwise.db so chat history survives redeploys.
DB_PATH=./hoodwise.db

# --- Chat limits (sane defaults, override only if you know you need to) ---
MAX_MESSAGE_LENGTH=4000
MAX_HISTORY_MESSAGES=20
MAX_OUTPUT_TOKENS=900

# --- Abuse protection: N requests per IP/session per time window ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# --- Optional "keep learning" layer (live web search) ---
# Completely optional. Leave blank/unset and Hoodwise works exactly as
# before, answering from the static knowledge base only. Set a key from
# https://tavily.com (has a free tier) to let Hoodwise pull a few live
# search results for questions that look time-sensitive ("latest", "today",
# "price", "trending", etc.) and fold them into that one reply.
TAVILY_API_KEY=
SEARCH_MAX_RESULTS=4
SEARCH_TIMEOUT_MS=6000
